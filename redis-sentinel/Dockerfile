FROM redis:7.2-alpine

# supervisorлҠ” /usr/bin/supervisord лЎң к№”лҰҪлӢҲлӢӨ. python3 мқҳмЎҙм„ұлҸ„ н•Ёк»ҳ м„Өм№ҳ.
RUN apk add --no-cache python3 supervisor bash


# л””л үнҶ лҰ¬
RUN mkdir -p /etc/redis /data /var/log/supervisor

# м„Өм • ліөмӮ¬
COPY redis/redis.conf /etc/redis/redis.conf
COPY redis/sentinel.conf /etc/redis/sentinel.conf
COPY supervisord.conf /etc/supervisord.conf

EXPOSE 6379 26379
VOLUME ["/data"]

# мӨ‘мҡ”: м ҲлҢҖкІҪлЎңлЎң supervisord мӢӨн–ү
CMD ["/usr/bin/supervisord", "-c", "/etc/supervisord.conf"]
